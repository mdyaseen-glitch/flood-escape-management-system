<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="/style.css" />

  <style>
    .search-wrap { position: relative; }
    .search-input {
      width: 100%;
      background: var(--bg-dark);
      border: 1px solid var(--border-light);
      border-radius: 6px;
      padding: 8px 10px;
      color: var(--text-primary);
      font-family: var(--font-mono);
      font-size: 12px;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-input:focus { border-color: var(--accent-route); }
    .search-input::placeholder { color: var(--text-muted); }

    .dropdown-list {
      position: absolute;
      top: 100%; left: 0; right: 0;
      background: var(--bg-card2);
      border: 1px solid var(--border-light);
      border-top: none;
      border-radius: 0 0 6px 6px;
      max-height: 200px;
      overflow-y: auto;
      z-index: 9999;
      display: none;
    }
    .dropdown-list.open { display: block; }
    .dropdown-item {
      padding: 7px 10px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-secondary);
      cursor: pointer;
      border-bottom: 1px solid var(--border);
    }
    .dropdown-item:hover { background: var(--accent-route); color: var(--bg-dark); }
    .dropdown-list::-webkit-scrollbar { width: 4px; }
    .dropdown-list::-webkit-scrollbar-thumb { background: var(--border-light); }

    .node-tooltip {
      background: #0f1526 !important;
      border: 1px solid #1e2d50 !important;
      color: #e8edf5 !important;
      font-family: 'Space Mono', monospace !important;
      font-size: 11px !important;
      padding: 3px 7px !important;
      border-radius: 4px !important;
      box-shadow: none !important;
    }
    .node-tooltip::before { display: none !important; }

    .filter-tabs { display: flex; gap: 6px; margin-bottom: 10px; }
    .filter-tab {
      flex: 1; padding: 5px 4px; border-radius: 5px;
      border: 1px solid var(--border-light);
      background: var(--bg-dark); color: var(--text-muted);
      font-family: var(--font-mono); font-size: 10px;
      cursor: pointer; text-align: center; transition: all 0.2s;
    }
    .filter-tab.active-red    { background: rgba(255,59,59,0.2);  border-color: #ff3b3b; color: #ff3b3b; }
    .filter-tab.active-yellow { background: rgba(255,230,0,0.15); border-color: #ffe600; color: #ffe600; }
    .filter-tab.active-green  { background: rgba(0,230,118,0.15); border-color: #00e676; color: #00e676; }
    .filter-tab.active-all    { background: rgba(0,188,212,0.15); border-color: #00bcd4; color: #00bcd4; }

    .tip-box {
      margin-top: 10px; padding: 8px 10px;
      background: var(--bg-dark); border: 1px solid var(--border);
      border-radius: 6px; font-family: var(--font-mono);
      font-size: 10px; color: var(--text-muted); line-height: 1.6;
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header-inner">
      <div class="logo">
        <span class="logo-icon">🌊</span>
        <span>
          <span class="logo-title">FloodNav</span>
          <span class="logo-sub">KORAMANGALA · REAL OSM ROADS · BENGALURU</span>
        </span>
      </div>
      <div class="header-status">
        <div class="pulse-dot"></div>
        <span>LIVE · KORAMANGALA</span>
      </div>
    </div>
  </header>

  <div class="app-layout">
    <aside class="sidebar">

      <!-- Route Planner -->
      <div class="card">
        <div class="card-title">🗺 Route Planner</div>
        <p class="card-desc">Type to search or click the map to pick points.</p>

        <div class="form-group">
          <label>From</label>
          <div class="search-wrap">
            <input type="text" id="srcInput" class="search-input" placeholder="Search start point…" autocomplete="off" />
            <div class="dropdown-list" id="srcDropdown"></div>
            <input type="hidden" id="sourceId" />
          </div>
        </div>

        <div class="swap-btn-wrap">
          <button onclick="swapLocations()" title="Swap">⇅</button>
        </div>

        <div class="form-group">
          <label>To</label>
          <div class="search-wrap">
            <input type="text" id="dstInput" class="search-input" placeholder="Search destination…" autocomplete="off" />
            <div class="dropdown-list" id="dstDropdown"></div>
            <input type="hidden" id="destId" />
          </div>
        </div>

        <button class="btn-primary" onclick="calculateRoute()">⚡ Find Safe Route</button>
        <button class="btn-secondary" onclick="clearAll()" style="margin-top:8px">✕ Clear</button>

        <div class="tip-box">
          💡 <b style="color:var(--text-secondary)">Tip:</b> Click the map to set source, click again to set destination.
        </div>
      </div>

      <!-- Legend -->
      <div class="card">
        <div class="card-title">🗂 Road Status</div>
        <div class="legend-items">
          <div class="legend-item">
            <div class="legend-dot" style="background:#ff3b3b;box-shadow:0 0 6px #ff3b3b"></div>
            <span><b style="color:#ff3b3b">RED</b> — Flooded, impassable</span>
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#ffe600;box-shadow:0 0 5px #ffe600"></div>
            <span><b style="color:#ffe600">YELLOW</b> — Waterlogged, passable</span>
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#00e676;box-shadow:0 0 5px #00e676"></div>
            <span><b style="color:#00e676">GREEN</b> — Safe, no water</span>
          </div>
          <div class="legend-item" style="margin-top:6px">
            <div class="legend-dot" style="background:#1976D2;box-shadow:0 0 6px #1976D2"></div>
            <span><b style="color:#42A5F5">BLUE</b> — Recommended safe route</span>
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#ff9800"></div>
            <span><b style="color:#ff9800">ORANGE</b> — Shortest route</span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="card">
        <div class="card-title">📊 Live Stats</div>
        <div class="stats-grid" id="statsGrid">
          <div class="stat-box loading"></div>
          <div class="stat-box loading"></div>
          <div class="stat-box loading"></div>
          <div class="stat-box loading"></div>
        </div>
      </div>

      <!-- Filter -->
      <div class="card">
        <div class="card-title">🔍 Filter Roads</div>
        <div class="filter-tabs">
          <div class="filter-tab active-all" id="tab-all"    onclick="filterRoads('all')">ALL</div>
          <div class="filter-tab"            id="tab-red"    onclick="filterRoads('red')">🔴</div>
          <div class="filter-tab"            id="tab-yellow" onclick="filterRoads('yellow')">🟡</div>
          <div class="filter-tab"            id="tab-green"  onclick="filterRoads('green')">🟢</div>
        </div>
        <div style="font-family:'Space Mono',monospace;font-size:10px;color:var(--text-muted)">
          Click any road on the map to see its details.
        </div>
      </div>

    </aside>

    <div class="map-container">
      <div id="map"></div>
      <div class="map-loading" id="mapLoading">
        <div class="loader-ring"></div>
        <p id="loadingText">LOADING…</p>
      </div>
      <div class="route-result hidden" id="routeResult">
        <button class="close-btn" onclick="closeResult()">✕</button>
        <div id="routeResultContent"></div>
      </div>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // ── SERVER DATA ───────────────────────────────────────────────────
    const ALL_NODES = <%- JSON.stringify(nodes) %>;
    const ALL_ROADS = <%- JSON.stringify(roads) %>;

    // ── MAP SETUP ─────────────────────────────────────────────────────
    const map = L.map('map', { center: [12.9360, 77.6245], zoom: 15 });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19
    }).addTo(map);

    // Three separate layer groups — roads, route lines, pin markers
    // Keeping them separate means clearing route never touches pins or roads
    const roadLayer  = L.layerGroup().addTo(map);
    const routeLayer = L.layerGroup().addTo(map);
    const pinLayer   = L.layerGroup().addTo(map);  // ← pins live here, never cleared by route draw

    // ── STATUS CONFIG ─────────────────────────────────────────────────
    const STATUS_CFG = {
      red:    { color: '#ff3b3b', weight: 4, dash: '7 4',  label: '🔴 Flooded — Impassable'    },
      yellow: { color: '#ffe600', weight: 4, dash: '10 4', label: '🟡 Waterlogged — Drive Slow' },
      green:  { color: '#00e676', weight: 3, dash: null,   label: '🟢 Safe — No Water'          }
    };

    // ── DRAW ALL ROADS ────────────────────────────────────────────────
    const roadPolylines = {};

    function drawAllRoads() {
      roadLayer.clearLayers();
      ALL_ROADS.forEach(road => {
        const cfg  = STATUS_CFG[road.status];
        const opts = { color: cfg.color, weight: cfg.weight, opacity: 0.85 };
        if (cfg.dash) opts.dashArray = cfg.dash;

        const line = L.polyline(road.coords, opts);
        line.bindPopup(`
          <div style="font-family:sans-serif;padding:8px 10px;min-width:190px">
            <b style="font-size:13px">${road.name}</b><br/>
            <span style="color:${cfg.color};font-weight:700;font-size:11px">${cfg.label}</span><br/>
            <span style="font-size:11px;color:#888">${road.distance} km · ${road.highway}</span>
          </div>
        `);
        roadLayer.addLayer(line);
        roadPolylines[road.id] = { line, status: road.status };
      });
    }

    // ── FILTER ────────────────────────────────────────────────────────
    function filterRoads(filter) {
      ['all','red','yellow','green'].forEach(f => {
        document.getElementById('tab-' + f).className =
          'filter-tab' + (f === filter ? ' active-' + f : '');
      });
      Object.values(roadPolylines).forEach(({ line, status }) => {
        const show = filter === 'all' || status === filter;
        if (show && !roadLayer.hasLayer(line)) roadLayer.addLayer(line);
        if (!show && roadLayer.hasLayer(line)) roadLayer.removeLayer(line);
      });
    }

    // ── STATS ─────────────────────────────────────────────────────────
    async function loadStats() {
      try {
        const res  = await fetch('/api/flood/stats');
        const data = await res.json();
        if (!data.success) return;
        const s = data.stats;
        document.getElementById('statsGrid').innerHTML =
          '<div class="stat-box"><div class="stat-number danger">' + s.red + '</div><div class="stat-label">🔴 Flooded</div></div>' +
          '<div class="stat-box"><div class="stat-number warn">'   + s.yellow + '</div><div class="stat-label">🟡 Caution</div></div>' +
          '<div class="stat-box"><div class="stat-number safe-c">' + s.green + '</div><div class="stat-label">🟢 Safe</div></div>' +
          '<div class="stat-box"><div class="stat-number info">'   + s.total + '</div><div class="stat-label">Total</div></div>';
      } catch(e) { console.error('Stats error:', e); }
    }

    // ── PIN MANAGEMENT ────────────────────────────────────────────────
    // Pins live in pinLayer — completely independent of routeLayer
    let srcPin = null;
    let dstPin = null;

    function makePinIcon(color) {
      return L.divIcon({
        className: '',
        html: '<div style="background:' + color + ';width:16px;height:16px;border-radius:50%;border:3px solid #fff;box-shadow:0 0 12px ' + color + '"></div>',
        iconSize:   [16, 16],
        iconAnchor: [8, 8]
      });
    }

    function setSourcePin(node) {
      if (srcPin) { pinLayer.removeLayer(srcPin); srcPin = null; }
      srcPin = L.marker([node.lat, node.lng], { icon: makePinIcon('#00e676') })
        .bindTooltip('🟢 START: ' + node.name, { permanent: true, direction: 'top', className: 'node-tooltip', offset: [0, -12] })
        .addTo(pinLayer);
    }

    function setDestPin(node) {
      if (dstPin) { pinLayer.removeLayer(dstPin); dstPin = null; }
      dstPin = L.marker([node.lat, node.lng], { icon: makePinIcon('#ff3b3b') })
        .bindTooltip('🔴 END: ' + node.name, { permanent: true, direction: 'top', className: 'node-tooltip', offset: [0, -12] })
        .addTo(pinLayer);
    }

    function clearPins() {
      if (srcPin) { pinLayer.removeLayer(srcPin); srcPin = null; }
      if (dstPin) { pinLayer.removeLayer(dstPin); dstPin = null; }
    }

    // ── SEARCHABLE DROPDOWN ───────────────────────────────────────────
    function buildDropdown(inputId, dropdownId, hiddenId, type) {
      const input    = document.getElementById(inputId);
      const dropdown = document.getElementById(dropdownId);
      const hidden   = document.getElementById(hiddenId);

      input.addEventListener('input', function() {
        const q = input.value.trim().toLowerCase();
        if (q.length < 2) { dropdown.classList.remove('open'); return; }

        const matches = ALL_NODES.filter(n => n.name.toLowerCase().includes(q)).slice(0, 30);
        if (!matches.length) { dropdown.classList.remove('open'); return; }

        dropdown.innerHTML = matches.map(n =>
          '<div class="dropdown-item" data-id="' + n.id + '" data-name="' + n.name + '">' + n.name + '</div>'
        ).join('');
        dropdown.classList.add('open');

        dropdown.querySelectorAll('.dropdown-item').forEach(function(item) {
          item.addEventListener('mousedown', function(e) {
            e.preventDefault();
            const node = ALL_NODES.find(n => n.id === item.dataset.id);
            if (!node) return;
            input.value  = node.name;
            hidden.value = node.id;
            dropdown.classList.remove('open');
            if (type === 'src') setSourcePin(node);
            else                setDestPin(node);
            map.setView([node.lat, node.lng], 16);
          });
        });
      });

      input.addEventListener('blur', function() {
        setTimeout(function() { dropdown.classList.remove('open'); }, 200);
      });

      // If user clears the text manually, clear the hidden id too
      input.addEventListener('change', function() {
        if (!input.value.trim()) hidden.value = '';
      });
    }

    buildDropdown('srcInput', 'srcDropdown', 'sourceId', 'src');
    buildDropdown('dstInput', 'dstDropdown', 'destId',   'dst');

    // ── MAP CLICK → NEAREST NODE ──────────────────────────────────────
    function nearestNode(lat, lng) {
      let best = null, bestDist = Infinity;
      for (let i = 0; i < ALL_NODES.length; i++) {
        const n = ALL_NODES[i];
        const d = Math.hypot(n.lat - lat, n.lng - lng);
        if (d < bestDist) { bestDist = d; best = n; }
      }
      return best;
    }

    map.on('click', function(e) {
      const node = nearestNode(e.latlng.lat, e.latlng.lng);
      if (!node) return;

      const srcId    = document.getElementById('sourceId');
      const dstId    = document.getElementById('destId');
      const srcInput = document.getElementById('srcInput');
      const dstInput = document.getElementById('dstInput');

      if (!srcId.value) {
        // Set source
        srcId.value    = node.id;
        srcInput.value = node.name;
        setSourcePin(node);
        flash(srcInput, '#00e676');

      } else if (!dstId.value) {
        // Set destination
        dstId.value    = node.id;
        dstInput.value = node.name;
        setDestPin(node);
        flash(dstInput, '#ff3b3b');

      } else {
        // Both set — reset and start over with new source
        clearAll();
        srcId.value    = node.id;
        srcInput.value = node.name;
        setSourcePin(node);
        flash(srcInput, '#00e676');
      }
    });

    function flash(el, color) {
      el.style.borderColor = color;
      setTimeout(function() { el.style.borderColor = ''; }, 1500);
    }

    // ── ROUTE CALCULATION ─────────────────────────────────────────────
    async function calculateRoute() {
      const sourceId = document.getElementById('sourceId').value.trim();
      const destId   = document.getElementById('destId').value.trim();

      if (!sourceId) { alert('Please set a start point (search or click map).'); return; }
      if (!destId)   { alert('Please set a destination (search or click map).'); return; }
      if (sourceId === destId) { alert('Start and destination must be different.'); return; }

      showLoading('CALCULATING SAFE ROUTE…');

      try {
        const res = await fetch('/api/route/calculate', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ sourceId, destId })
        });
        const data = await res.json();
        hideLoading();

        if (!data.success) {
          alert('Server error: ' + data.message);
          return;
        }

        drawRouteOnMap(data);
        showRoutePanel(data);

      } catch(e) {
        hideLoading();
        console.error('Route error:', e);
        alert('Network error — is the server running?');
      }
    }

    // ── DRAW ROUTE ────────────────────────────────────────────────────
    // Only clears routeLayer — pins and roads are untouched
    function drawRouteOnMap(data) {
      routeLayer.clearLayers();

      // Orange dashed — shortest/normal route (drawn first, underneath)
      if (data.normalRoute && data.normalRoute.polyline && data.normalRoute.polyline.length) {
        L.polyline(data.normalRoute.polyline, {
          color: '#ff9800', weight: 12, opacity: 0.12
        }).addTo(routeLayer);
        L.polyline(data.normalRoute.polyline, {
          color: '#ff9800', weight: 5, opacity: 0.85, dashArray: '10 6'
        }).bindPopup('<b style="color:#ff9800">⚠ Shortest Route</b><br/>May pass through flooded roads')
          .addTo(routeLayer);
      }

      // Blue solid — safe route (drawn on top)
      if (data.safeRoute && data.safeRoute.polyline && data.safeRoute.polyline.length) {
        L.polyline(data.safeRoute.polyline, {
          color: '#1565C0', weight: 18, opacity: 0.18
        }).addTo(routeLayer);
        L.polyline(data.safeRoute.polyline, {
          color: '#1976D2', weight: 6, opacity: 1
        }).bindPopup('<b style="color:#42A5F5">✅ Safe Route</b><br/>Avoids all flooded roads')
          .addTo(routeLayer);
      }

      // Fit map to the safe route (or normal if no safe)
      const fitPoly = (data.safeRoute || data.normalRoute);
      if (fitPoly && fitPoly.polyline && fitPoly.polyline.length) {
        map.fitBounds(L.latLngBounds(fitPoly.polyline), { padding: [60, 60] });
      }
    }

    // ── ROUTE RESULT PANEL ────────────────────────────────────────────
    function showRoutePanel(data) {
      const panel   = document.getElementById('routeResult');
      const content = document.getElementById('routeResultContent');

      let html = '<div style="font-weight:800;font-size:13px;margin-bottom:12px;color:#e8edf5;line-height:1.5">'
        + data.source.name
        + '<br/><span style="color:#8899bb;font-size:11px">↓ to</span><br/>'
        + data.destination.name
        + '</div>';

      // Safe route block
      if (data.safeRoute) {
        const r = data.safeRoute;
        const note = r.hasYellow
          ? '<span style="color:#ffe600;font-size:10px">⚠ Passes waterlogged roads — drive carefully</span>'
          : '<span style="color:#00e676;font-size:10px">✅ Fully safe — no water on route</span>';

        const roadRows = r.roads.map(function(rd) {
          const c = STATUS_CFG[rd.status] ? STATUS_CFG[rd.status].color : '#888';
          return '<div style="display:flex;align-items:center;gap:6px;font-family:\'Space Mono\',monospace;font-size:10px;color:#8899bb">'
            + '<div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:' + c + '"></div>'
            + '<span style="flex:1">' + rd.name + '</span>'
            + '<span style="color:' + c + ';text-transform:uppercase">' + rd.status + '</span>'
            + '</div>';
        }).join('');

        html += '<div class="result-section">'
          + '<div class="result-header">'
          + '<span class="result-badge" style="background:rgba(25,118,210,0.15);color:#42A5F5;border:1px solid #1976D2;border-radius:20px;font-size:10px;padding:2px 8px;font-weight:700">✅ SAFE ROUTE</span>'
          + '<span style="font-family:\'Space Mono\',monospace;font-size:11px;color:#8899bb">' + r.totalDistance + ' km</span>'
          + '</div>'
          + note
          + '<div style="margin-top:8px;display:flex;flex-direction:column;gap:3px">' + roadRows + '</div>'
          + '</div>'
          + '<div class="result-divider"></div>';
      } else {
        html += '<div class="no-route-msg">⚠️ No flood-safe route found. All paths are blocked.</div>'
          + '<div class="result-divider"></div>';
      }

      // Normal route block
      if (data.normalRoute) {
        const r = data.normalRoute;
        html += '<div class="result-section">'
          + '<div class="result-header">'
          + '<span class="result-badge warn-badge">⚠ SHORTEST ROUTE</span>'
          + '<span style="font-family:\'Space Mono\',monospace;font-size:11px;color:#8899bb">' + r.totalDistance + ' km</span>'
          + '</div>'
          + '<span style="color:#ff9800;font-size:10px">May pass through flooded roads</span>'
          + '</div>';
      }

      // Comparison
      if (data.safeRoute && data.normalRoute) {
        const diff = Math.round((data.safeRoute.totalDistance - data.normalRoute.totalDistance) * 10) / 10;
        html += '<div class="result-divider"></div>'
          + '<div class="result-summary">'
          + 'Safe route is <span>' + (diff >= 0 ? '+' : '') + diff + ' km</span> vs shortest.<br/>'
          + '<span style="color:#00e676">Recommendation: Take the safe route.</span>'
          + '</div>';
      }

      content.innerHTML = html;
      panel.classList.remove('hidden');
    }

    function closeResult() {
      document.getElementById('routeResult').classList.add('hidden');
    }

    // ── CLEAR ALL ─────────────────────────────────────────────────────
    function clearAll() {
      routeLayer.clearLayers();
      clearPins();
      closeResult();
      document.getElementById('srcInput').value  = '';
      document.getElementById('dstInput').value  = '';
      document.getElementById('sourceId').value  = '';
      document.getElementById('destId').value    = '';
    }

    function swapLocations() {
      const srcInput = document.getElementById('srcInput');
      const dstInput = document.getElementById('dstInput');
      const srcId    = document.getElementById('sourceId');
      const dstId    = document.getElementById('destId');

      const tmpText = srcInput.value;
      const tmpId   = srcId.value;
      srcInput.value = dstInput.value;
      srcId.value    = dstId.value;
      dstInput.value = tmpText;
      dstId.value    = tmpId;

      // Swap pins too
      const tmpPin = srcPin;
      srcPin = dstPin;
      dstPin = tmpPin;
      // Re-colour them
      if (srcPin) { srcPin.setIcon(makePinIcon('#00e676')); }
      if (dstPin) { dstPin.setIcon(makePinIcon('#ff3b3b')); }
    }

    // ── LOADING ───────────────────────────────────────────────────────
    function showLoading(t) {
      document.getElementById('loadingText').textContent = t || 'LOADING…';
      document.getElementById('mapLoading').classList.add('active');
    }
    function hideLoading() {
      document.getElementById('mapLoading').classList.remove('active');
    }

    // ── INIT ──────────────────────────────────────────────────────────
    showLoading('LOADING ROAD NETWORK…');
    drawAllRoads();
    loadStats();
    hideLoading();
  </script>

</body>
